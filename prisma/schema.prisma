generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  VIEWER
}

// Mirrors a Supabase auth.users row (matched by id) so we can attach an
// app-specific role without Prisma needing to manage the auth schema itself.
model UserProfile {
  id        String   @id
  email     String   @unique
  role      UserRole @default(VIEWER)
  createdAt DateTime @default(now())
}

// Logs the first time the admin opens a given entity's panel - a real
// "visited/attended/met" signal rather than just counting rows that exist.
model Visit {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  visitedAt  DateTime @default(now())

  @@unique([entityType, entityId])
}

// Anonymous, low-friction "suggest a spot/event/opportunity" inbox - not a
// live entity until the admin reviews it and decides to act on it.
model Suggestion {
  id          String   @id @default(cuid())
  type        String
  description String
  contactInfo String?
  reviewed    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Organization {
  entityId      String   @id
  name          String
  category      String
  subtype       String
  description   String
  industry      String?
  logo          String?
  lat           Float
  lng           Float
  website       String?
  linkedin      String?
  founded       Int?
  employeeCount Int?
  stage         String?
  headquarters  String?
  techStack     String[]
  aiStack       String[]
  founderIds    String[]
  placeId       String?
  eventIds      String[]
}

model Person {
  entityId        String   @id
  name            String
  role            String
  bio             String?
  linkedin        String?
  organizationIds String[]
}

model Place {
  entityId String  @id
  name     String
  category String
  subtype  String
  lat      Float
  lng      Float
  address  String?
}

model Event {
  entityId        String   @id
  name            String
  category        String
  subtype         String?
  date            String
  lat             Float
  lng             Float
  organizationIds String[]
}

model Content {
  entityId               String   @id
  name                   String
  category               String
  links                  Json
  publishedAt            String
  relatedOrganizationIds String[]
  relatedEventIds        String[]
}

model Journal {
  entityId               String   @id
  name                   String
  category               String
  body                   String
  date                   String
  relatedOrganizationIds String[]
  relatedEventIds        String[]
}
